from typing import Any

class DuckDBPyConnection:
    def execute(self, query: str, parameters: Any = ...) -> DuckDBPyConnection: ...
    def executemany(self, query: str, parameters: Any = ...) -> DuckDBPyConnection: ...
    def fetchone(self) -> tuple[Any, ...] | None: ...
    def fetchall(self) -> list[tuple[Any, ...]]: ...
    def close(self) -> None: ...

def connect(database: str = ..., read_only: bool = ...) -> DuckDBPyConnection: ...
